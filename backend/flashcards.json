{
  "name": "flashcards",
  "primary_key_column": "id",
  "enable_rls": false,
  "visibility": "POD",
  "columns": [
    { "name": "paper_id", "type": "UUID", "required": true, "foreign_key": { "references": "academic_papers.id" } },
    { "name": "question", "type": "TEXT", "required": true },
    { "name": "answer", "type": "TEXT", "required": true },
    { "name": "difficulty", "type": "ENUM", "required": true, "default": "medium", "options": ["easy", "medium", "hard"] }
  ]
}
